{
  "openapi": "3.0.0",
  "info": {
    "title": "Knowledge Network Select Tool API",
    "description": "知识网络选择工具 API 文档。根据用户的问题或表信息，在知识网络列表中找到最匹配的知识网络，以便后续的问数功能使用。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://af-sailor-agent:9595",
      "description": "生产环境"
    }
  ],
  "paths": {
    "/api/af-sailor-agent/v1/assistant/tools/kn_select": {
      "post": {
        "summary": "知识网络选择",
        "description": "根据用户的问题或表信息，在知识网络列表中找到最匹配的知识网络。支持表匹配和问题匹配两种模式，表匹配优先级高于问题匹配。",
        "operationId": "knSelect",
        "tags": ["knowledge-network"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "llm": {
                    "type": "object",
                    "description": "LLM 配置参数（可选）",
                    "properties": {
                      "model_name": {
                        "type": "string",
                        "description": "模型名称"
                      },
                      "openai_api_key": {
                        "type": "string",
                        "description": "OpenAI API Key"
                      },
                      "openai_api_base": {
                        "type": "string",
                        "description": "OpenAI API Base URL"
                      }
                    }
                  },
                  "auth": {
                    "type": "object",
                    "description": "认证参数",
                    "properties": {
                      "auth_url": {
                        "type": "string",
                        "description": "认证服务URL（可选）",
                        "example": "http://auth-service:8155"
                      },
                      "user": {
                        "type": "string",
                        "description": "用户名（可选）",
                        "example": "admin"
                      },
                      "password": {
                        "type": "string",
                        "description": "密码（可选）",
                        "format": "password"
                      },
                      "token": {
                        "type": "string",
                        "description": "认证令牌，如提供则无需用户名和密码（推荐）",
                        "example": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                      },
                      "user_id": {
                        "type": "string",
                        "description": "用户ID（可选）",
                        "example": "123456"
                      }
                    }
                  },
                  "config": {
                    "type": "object",
                    "description": "工具配置参数",
                    "properties": {
                      "base_url": {
                        "type": "string",
                        "description": "AF 服务基础 URL（可选，覆盖默认服务地址）",
                        "example": "http://10.4.134.26"
                      },
                      "session_type": {
                        "type": "string",
                        "description": "会话类型",
                        "enum": ["in_memory", "redis"],
                        "default": "redis"
                      },
                      "background": {
                        "type": "string",
                        "description": "背景信息（可选）"
                      }
                    }
                  },
                  "query": {
                    "type": "string",
                    "description": "用户输入的问题（可选，如果提供了tables则优先使用表匹配）",
                    "example": "查询上市公司财务数据"
                  },
                  "tables": {
                    "type": "array",
                    "description": "表信息列表（可选），用于表匹配模式",
                    "items": {
                      "type": "object",
                      "required": ["id", "uuid", "business_name", "technical_name"],
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "视图的ID，用于匹配知识网络对象类型中的 data_source.id",
                          "example": "2008493788360966146"
                        },
                        "uuid": {
                          "type": "string",
                          "description": "视图的UUID",
                          "example": "c445f4d5-71e5-4617-8ccc-79ecd34b8bed"
                        },
                        "business_name": {
                          "type": "string",
                          "description": "视图的业务名称",
                          "example": "A股上市公司现金流量表"
                        },
                        "technical_name": {
                          "type": "string",
                          "description": "视图的技术名称",
                          "example": "cash_flow_table"
                        }
                      }
                    }
                  },
                  "force_refresh_cache": {
                    "type": "boolean",
                    "description": "是否强制刷新缓存（可选，默认为false）",
                    "default": false
                  }
                }
              },
              "examples": {
                "table_match": {
                  "summary": "表匹配模式示例",
                  "value": {
                    "auth": {
                      "token": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "tables": [
                      {
                        "id": "2008493788360966146",
                        "uuid": "c445f4d5-71e5-4617-8ccc-79ecd34b8bed",
                        "business_name": "A股上市公司现金流量表",
                        "technical_name": "cash_flow_table"
                      }
                    ]
                  }
                },
                "query_match": {
                  "summary": "问题匹配模式示例",
                  "value": {
                    "auth": {
                      "token": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "query": "查询上市公司财务数据"
                  }
                },
                "with_cache_refresh": {
                  "summary": "强制刷新缓存示例",
                  "value": {
                    "auth": {
                      "token": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "query": "查询上市公司财务数据",
                    "force_refresh_cache": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功响应",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "kn_id": {
                      "type": "string",
                      "description": "匹配到的知识网络ID，如果未匹配则为空字符串",
                      "example": "d5efgga6746ef0r11g1g"
                    },
                    "kn_name": {
                      "type": "string",
                      "description": "匹配到的知识网络名称，如果未匹配则为空字符串",
                      "example": "上市公司营收知识网络"
                    }
                  },
                  "required": ["kn_id", "kn_name"]
                },
                "examples": {
                  "success": {
                    "summary": "匹配成功",
                    "value": {
                      "kn_id": "d5efgga6746ef0r11g1g",
                      "kn_name": "上市公司营收知识网络"
                    }
                  },
                  "no_match": {
                    "summary": "未匹配到知识网络",
                    "value": {
                      "kn_id": "",
                      "kn_name": ""
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "错误信息"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "错误信息"
                    },
                    "detail": {
                      "type": "string",
                      "description": "错误详情"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TableInfo": {
        "type": "object",
        "required": ["id", "uuid", "business_name", "technical_name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "视图的ID，用于匹配知识网络对象类型中的 data_source.id"
          },
          "uuid": {
            "type": "string",
            "description": "视图的UUID"
          },
          "business_name": {
            "type": "string",
            "description": "视图的业务名称"
          },
          "technical_name": {
            "type": "string",
            "description": "视图的技术名称"
          }
        }
      },
      "KnowledgeNetworkResponse": {
        "type": "object",
        "required": ["kn_id", "kn_name"],
        "properties": {
          "kn_id": {
            "type": "string",
            "description": "匹配到的知识网络ID，如果未匹配则为空字符串"
          },
          "kn_name": {
            "type": "string",
            "description": "匹配到的知识网络名称，如果未匹配则为空字符串"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "knowledge-network",
      "description": "知识网络相关操作"
    }
  ]
}
