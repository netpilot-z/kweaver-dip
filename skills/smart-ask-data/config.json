{
  "name": "smart-ask-data",
  "version": "1.0.0",
  "base_url": "",
  "openclaw": {
    "skillKey": "smart-ask-data"
  },
  "description": "问数编排（仅查询返数）：Step1 确认 base_url/user_id/token/inner_llm.name（记忆区优先，无则用户确认）→ kn_select（如需）→ text2sql(show_ds → gen_exec) → 最小口径交付；不执行 execute_code_sync / json2plot；成功后删除临时脚本，_tmp_*.json/.ndjson 等临时数据默认保留",
  "defaults": {
    "user_id": "",
    "x_business_domain": "bd_public"
  },
  "tools": {
    "kn_select": {
      "url_path": "/api/af-sailor-agent/v1/assistant/tools/kn_select",
      "kn_ids": [],
      "forbidden_ask_data_kn_ids": ["idrm_metadata_kn_object_lbb"]
    },
    "text2sql": {
      "url_path": "/api/af-sailor-agent/v1/assistant/tools/text2sql",
      "kn_id": "",
      "background": {
        "show_ds": "",
        "gen_exec_template": "注册资金单位为万"
      },
      "inner_llm": {
        "id": "",
        "name": "",
        "temperature": 0.1,
        "top_k": 1,
        "top_p": 1,
        "frequency_penalty": 0,
        "presence_penalty": 0,
        "max_tokens": 20000
      }
    },
    "execute_code_sync": {
      "url_path": "/api/v1/executions/sessions/sess-agent-default/execute-sync",
      "kn_id": ""
    },
    "json2plot": {
      "url_path": "/api/af-sailor-agent/v1/assistant/tools/json2plot",
      "kn_id": ""
    }
  },
  "pipeline": [
    {
      "step": 1,
      "role": "resolve_kn",
      "tool_skill": "kn_select",
      "skill_path": "skills/kn_select/SKILL.md",
      "config_path": "skills/kn_select/config.json",
      "defaults_key": "kn_select",
      "reference": "skills/smart-ask-data/references/kn-select.md"
    },
    {
      "step": 2,
      "role": "discover_schema",
      "tool_skill": "text2sql",
      "action": "show_ds",
      "skill_path": "skills/text2sql/SKILL.md",
      "config_path": "skills/text2sql/config.json",
      "defaults_key": "text2sql",
      "reference": "skills/smart-ask-data/references/text2sql.md"
    },
    {
      "step": 3,
      "role": "query_data",
      "tool_skill": "text2sql",
      "action": "gen_exec",
      "background_from": "tools.text2sql.background.gen_exec_template",
      "skill_path": "skills/text2sql/SKILL.md",
      "config_path": "skills/text2sql/config.json",
      "defaults_key": "text2sql",
      "reference": "skills/smart-ask-data/references/text2sql.md"
    },
    {
      "step": 4,
      "role": "post_process",
      "tool_skill": "execute_code_sync",
      "optional": true,
      "skill_path": "skills/execute_code_sync/SKILL.md",
      "config_path": "skills/execute_code_sync/config.json",
      "defaults_key": "execute_code_sync",
      "reference": "skills/smart-ask-data/references/execute-code-sync.md"
    },
    {
      "step": 5,
      "role": "chart",
      "tool_skill": "json2plot",
      "optional": true,
      "skill_path": "skills/json2plot/SKILL.md",
      "config_path": "skills/json2plot/config.json",
      "defaults_key": "json2plot",
      "reference": "skills/smart-ask-data/references/json2plot.md"
    }
  ]
}
